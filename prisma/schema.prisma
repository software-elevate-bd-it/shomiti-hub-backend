generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name     String
  email    String   @unique
  password String
  role     UserRole @default(main_user)
  phone    String?

  somiteeId BigInt?  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee? @relation("UserSomitee", fields: [somiteeId], references: [id], onDelete: SetNull)

  createdById  BigInt? @map("created_by_id") @db.UnsignedBigInt
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  updatedById  BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy    User?   @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedUsers User[]  @relation("UserUpdatedBy")

  // Managed user relations
  createdSomitees Somitee[] @relation("SomiteeCreatedBy")
  updatedSomitees Somitee[] @relation("SomiteeUpdatedBy")

  // Member relations
  memberCreated Member[] @relation("MemberCreatedBy")
  memberUpdated Member[] @relation("MemberUpdatedBy")

  // MemberRequest relations
  memberRequests        MemberRequest[] @relation("MemberRequestCreatedBy")
  memberRequestsUpdated MemberRequest[] @relation("MemberRequestUpdatedBy")

  // Payment relations
  paymentsCreated Payment[] @relation("PaymentCreatedBy")
  paymentsUpdated Payment[] @relation("PaymentUpdatedBy")

  // PaymentItem relations
  paymentItemsCreated PaymentItem[] @relation("PaymentItemCreatedBy")
  paymentItemsUpdated PaymentItem[] @relation("PaymentItemUpdatedBy")

  // Transaction relations
  transactionsCreated Transaction[] @relation("TransactionCreatedBy")
  transactionsUpdated Transaction[] @relation("TransactionUpdatedBy")

  // Expense relations
  expensesCreated Expense[] @relation("ExpenseCreatedBy")
  expensesUpdated Expense[] @relation("ExpenseUpdatedBy")

  // CashBook relations
  cashEntriesCreated CashBookEntry[] @relation("CashBookCreatedBy")
  cashEntriesUpdated CashBookEntry[] @relation("CashBookUpdatedBy")

  // BankAccount relations
  bankAccountsCreated BankAccount[] @relation("BankAccountCreatedBy")
  bankAccountsUpdated BankAccount[] @relation("BankAccountUpdatedBy")

  // BankTransaction relations
  bankTxCreated BankTransaction[] @relation("BankTransactionCreatedBy")
  bankTxUpdated BankTransaction[] @relation("BankTransactionUpdatedBy")

  // Stats relations
  statsCreated StatsSummary[] @relation("StatsCreatedBy")
  statsUpdated StatsSummary[] @relation("StatsUpdatedBy")

  // Ledger relations
  ledgerCreated LedgerEntry[] @relation("LedgerCreatedBy")
  ledgerUpdated LedgerEntry[] @relation("LedgerUpdatedBy")

  // Approval relations
  approvalsCreated  Approval[] @relation("ApprovalCreatedBy")
  approvalsReviewed Approval[] @relation("ApprovalReviewedBy")

  // Role assignment relations
  roleAssignments UserRoleAssignment[] @relation("UserRoleAssignments")

  // SMS Config relation
  smsConfigs SmsConfig[] @relation("SmsConfigCreatedBy")

  // New fields for managed users
  roleIds   Json       @default("[]") @map("role_ids")
  status    UserStatus @default(active)
  isManaged Boolean    @default(false) @map("is_managed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  super_admin
  main_user
  member
}

enum UserStatus {
  active
  inactive
}

model Somitee {
  id            BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name          String
  email         String
  phone         String
  status        SomiteeStatus @default(active)
  plan          String        @default("basic")
  blockedReason String?

  createdById BigInt? @map("created_by_id") @db.UnsignedBigInt
  createdBy   User?   @relation("SomiteeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("SomiteeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Relations
  members          Member[]
  requests         MemberRequest[]
  payments         Payment[]
  transactions     Transaction[]
  expenses         Expense[]
  bankAccounts     BankAccount[]
  paymentItems     PaymentItem[]
  cashBookEntries  CashBookEntry[]
  bankTransactions BankTransaction[]
  ledgerEntries    LedgerEntry[]
  statsSummaries   StatsSummary[]
  users            User[]            @relation("UserSomitee")
  roles            Role[]
  approvals        Approval[]
  smsTemplates     SmsTemplate[]
  smsHistories     SmsHistory[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  companySettings  CompanySettings[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([updatedById])
  @@index([createdAt])
  @@map("somitees")
}

enum SomiteeStatus {
  active
  blocked
}

model Member {
  id       BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  name     String
  shopName String       @map("shop_name")
  phone    String
  address  String?
  nid      String       @unique
  status   MemberStatus @default(active)

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("MemberCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("MemberUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  monthlyFee   Int
  billingCycle String   @default("monthly") @map("billing_cycle")
  totalDue     Int      @default(0) @map("total_due")
  totalPaid    Int      @default(0) @map("total_paid")
  joinDate     DateTime @default(now()) @map("join_date")

  // Relations
  payments      Payment[]
  paymentItems  PaymentItem[]
  transactions  Transaction[]
  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, status])
  @@map("members")
}

enum MemberStatus {
  active
  inactive
}

model MemberRequest {
  id       BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  memberId BigInt?       @unique @map("member_id") @db.UnsignedBigInt
  status   RequestStatus @default(pending)

  // Personal Information
  nameBn      String   @map("name_bn")
  nameEn      String   @map("name_en")
  fatherName  String   @map("father_name")
  motherName  String   @map("mother_name")
  dob         DateTime @map("date_of_birth")
  nationality String
  religion    String
  bloodGroup  String   @map("blood_group")

  // Contact Information
  mobile   String
  village  String?
  wardNo   String? @map("ward_no")
  union    String?
  upazila  String?
  district String?

  // Business Information
  shopName String @map("shop_name")

  // Identification
  nid String @unique

  // Nominee Information
  nomineeName     String @map("nominee_name")
  nomineeRelation String @map("nominee_relation")
  nomineeNid      String @map("nominee_nid")

  // Financial Information
  monthlyFee   Int    @map("monthly_fee")
  billingCycle String @default("monthly") @map("billing_cycle")

  // Images
  profileImageUrl String? @map("profile_image_url")
  nidFrontUrl     String? @map("nid_front_url")
  nidBackUrl      String? @map("nid_back_url")
  signatureUrl    String? @map("signature_url")

  // Metadata
  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("MemberRequestCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("MemberRequestUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Approval Information
  rejectionNote String?   @map("rejection_note")
  approvedAt    DateTime? @map("approved_at")
  approvedBy    BigInt?   @map("approved_by") @db.UnsignedBigInt
  rejectedAt    DateTime? @map("rejected_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, status])
  @@map("member_requests")
}

enum RequestStatus {
  pending
  approved
  rejected
  draft
}

model Payment {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  memberId      BigInt    @map("member_id") @db.UnsignedBigInt
  member        Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount        Int
  paymentDate   DateTime  @map("payment_date")
  method        String
  status        String    @default("pending")
  category      String?
  transactionId String?   @map("transaction_id")
  note          String?
  verifiedAt    DateTime? @map("verified_at")
  financialYear String?   @map("financial_year")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("PaymentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  paymentItems PaymentItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, memberId])
  @@index([somiteeId, paymentDate])
  @@index([somiteeId, financialYear])
  @@map("payments")
}

model PaymentItem {
  id            BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  paymentId     BigInt  @map("payment_id") @db.UnsignedBigInt
  payment       Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  memberId      BigInt  @map("member_id") @db.UnsignedBigInt
  member        Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  month         Int
  financialYear String  @map("financial_year")
  amount        Int

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("PaymentItemCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("PaymentItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([memberId, month, financialYear])
  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, memberId])
  @@index([somiteeId, financialYear])
  @@map("payment_items")
}

model Transaction {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  memberId      BigInt?   @map("member_id") @db.UnsignedBigInt
  member        Member?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberName    String?   @map("member_name")
  type          String
  amount        Int
  date          DateTime
  status        String
  method        String
  category      String?
  transactionId String?   @map("transaction_id")
  note          String?
  approvedAt    DateTime?

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("TransactionCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("TransactionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, memberId])
  @@index([somiteeId, date])
  @@map("transactions")
}

model Expense {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  amount     Int
  date       DateTime
  category   String
  method     String
  note       String?
  receiptUrl String?  @map("receipt_url")
  status     String   @default("approved")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, createdAt])
  @@map("expenses")
}

model CashBookEntry {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  date          DateTime
  description   String
  cashIn        Int
  cashOut       Int
  balance       Int
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("CashBookCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("CashBookUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, date])
  @@map("cash_book_entries")
}

model SmsTemplate {
  id        BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  name      String
  body      String @db.LongText
  variables Json
  type      String

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@map("sms_templates")
}

model SmsHistory {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  date       DateTime @default(now())
  template   String?
  recipients Int
  sent       Int
  failed     Int
  cost       Float?
  details    Json?

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  @@index([somiteeId])
  @@index([somiteeId, date])
  @@map("sms_history")
}

model SmsConfig {
  id                  BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  provider            String
  apiKey              String  @map("api_key")
  senderId            String  @map("sender_id")
  autoSendOnPayment   Boolean @default(false) @map("auto_send_on_payment")
  autoSendDueReminder Boolean @default(false) @map("auto_send_due_reminder")
  reminderDayOfMonth  Int?    @map("reminder_day_of_month")

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("SmsConfigCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@map("sms_configs")
}

model CompanySettings {
  id        BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  somiteeId BigInt  @unique @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)
  name      String
  logo      String?
  signature String?
  address   String?
  phone     String?
  email     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@map("company_settings")
}

model PrintTemplate {
  id              BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  showLogo        Boolean @default(true) @map("show_logo")
  showCompanyName Boolean @default(true) @map("show_company_name")
  showSignature   Boolean @default(true) @map("show_signature")
  showFooterNotes Boolean @default(true) @map("show_footer_notes")
  footerNotes     String? @map("footer_notes")
  marginTop       Int     @default(20) @map("margin_top")
  marginBottom    Int     @default(20) @map("margin_bottom")
  marginLeft      Int     @default(15) @map("margin_left")
  marginRight     Int     @default(15) @map("margin_right")
  paperSize       String  @default("A4") @map("paper_size")
  orientation     String  @default("portrait")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("print_templates")
}

model Faq {
  id       BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  question String
  answer   String @db.LongText
  category String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("faqs")
}

model Notification {
  id        BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  type      String
  title     String
  message   String  @db.LongText
  read      Boolean @default(false)
  actionUrl String? @map("action_url")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([somiteeId])
  @@index([somiteeId, read])
  @@index([somiteeId, createdAt])
  @@map("notifications")
}

model ActivityLog {
  id          BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  userId      BigInt  @map("user_id") @db.UnsignedBigInt
  userName    String  @map("user_name")
  action      String
  description String  @db.LongText
  metadata    Json?
  ipAddress   String? @map("ip_address")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([somiteeId])
  @@index([userId])
  @@index([somiteeId, createdAt])
  @@map("activity_logs")
}

model SubscriptionPlan {
  id         BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  name       String
  price      Int
  maxMembers Int    @map("max_members")
  features   Json
  status     String

  @@index([status])
  @@map("subscription_plans")
}

model BankAccount {
  id             BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  bankName       String @map("bank_name")
  accountName    String @map("account_name")
  accountNumber  String @map("account_number")
  balance        Int
  openingBalance Int    @map("opening_balance")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("BankAccountCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("BankAccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  transactions BankTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, createdAt])
  @@map("bank_accounts")
}

model BankTransaction {
  id            BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  bankAccountId BigInt      @map("bank_account_id") @db.UnsignedBigInt
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  type          String
  amount        Int
  date          DateTime
  note          String?
  reference     String?
  balanceAfter  Int         @map("balance_after")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("BankTransactionCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("BankTransactionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, bankAccountId])
  @@index([somiteeId, date])
  @@map("bank_transactions")
}

model StatsSummary {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  date            DateTime
  totalCollection Int      @map("total_collection")
  totalExpense    Int      @map("total_expense")
  totalDue        Int      @map("total_due")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  periodType StatsPeriodType @default(daily) @map("period_type")

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("StatsCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("StatsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([somiteeId, date, periodType])
  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, date])
  @@map("stats_summaries")
}

enum StatsPeriodType {
  daily
  monthly
}

model LedgerEntry {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  date          DateTime
  description   String
  type          String
  debit         Int?
  credit        Int?
  balance       Int
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")
  memberId      BigInt?  @map("member_id") @db.UnsignedBigInt
  member        Member?  @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberName    String?  @map("member_name")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdById BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy   User   @relation("LedgerCreatedBy", fields: [createdById], references: [id])

  updatedById BigInt? @map("updated_by_id") @db.UnsignedBigInt
  updatedBy   User?   @relation("LedgerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([somiteeId, memberId])
  @@index([somiteeId, createdAt])
  @@map("ledger_entries")
}

model Role {
  id          BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  name        String
  description String?
  permissions Json    @default("[]")
  isPreset    Boolean @default(false) @map("is_preset")

  somiteeId BigInt?  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee? @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assignments UserRoleAssignment[]

  @@unique([name, somiteeId])
  @@index([somiteeId])
  @@map("roles")
}

model UserRoleAssignment {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId     BigInt   @map("user_id") @db.UnsignedBigInt
  user       User     @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  roleId     BigInt   @map("role_id") @db.UnsignedBigInt
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

model Approval {
  id          BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  type        ApprovalType
  title       String
  amount      Int?
  description String?        @db.LongText
  status      ApprovalStatus @default(pending)
  payload     Json

  createdById   BigInt @map("created_by_id") @db.UnsignedBigInt
  createdBy     User   @relation("ApprovalCreatedBy", fields: [createdById], references: [id])
  createdByName String @map("created_by_name")

  reviewedById    BigInt?   @map("reviewed_by_id") @db.UnsignedBigInt
  reviewedBy      User?     @relation("ApprovalReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedByName  String?   @map("reviewed_by_name")
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionNote   String?   @map("rejection_note")
  createdRecordId String?   @map("created_record_id")

  somiteeId BigInt  @map("somitee_id") @db.UnsignedBigInt
  somitee   Somitee @relation(fields: [somiteeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([somiteeId])
  @@index([createdById])
  @@index([reviewedById])
  @@index([somiteeId, status])
  @@index([somiteeId, type])
  @@index([somiteeId, createdAt])
  @@map("approvals")
}

enum ApprovalType {
  collection
  expense
  bank
  member
}

enum ApprovalStatus {
  pending
  approved
  rejected
}
